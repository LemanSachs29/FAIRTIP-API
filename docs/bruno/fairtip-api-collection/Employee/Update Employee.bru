meta {
  name: Update Employee
  type: http
  seq: 4
}

put {
  url: http://127.0.0.1:5000/employees/:employee_id
  body: json
  auth: inherit
}

params:path {
  employee_id: 2
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Ana",
    "surname": "Garcia Lopez",
    "average_daily_hours": 7.5
  }
}

settings {
  encodeUrl: true
}
